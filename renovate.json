{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "postUpdateOptions": ["gomodTidy", "gomodUpdateImportPaths"],
  "automerge": true,
  "automergeType": "pr",
  "patch": {
    "automerge": true
  },
  "prCreation": "not-pending",
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^src/gitops/installer\\.go$/"
      ],
      "matchStrings": ["moacVersion\\s+=\\s+\"(?<currentValue>[^\"]+)\""],
      "datasourceTemplate": "helm",
      "depNameTemplate": "moac",
      "registryUrlTemplate": "https://helm.mogenius.com/public"
    },
    {
      "description": "Update the pinned snoopy release in the Dockerfile",
      "customType": "regex",
      "managerFilePatterns": [
        "/^Dockerfile$/"
      ],
      "matchStrings": ["SNOOPY_VERSION=(?<currentValue>v[\\d.]+)"],
      "depNameTemplate": "mogenius/snoopy",
      "datasourceTemplate": "github-releases"
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "ghcr.io/mogenius/mogenius-operator"
      ],
      "matchFileNames": [
        "helm/**"
      ],
      "enabled": false
    },
    {
      "description": "sealed-secrets renamed module path from bitnami-labs to bitnami at v0.38.x",
      "matchDatasources": ["go"],
      "matchPackageNames": ["github.com/bitnami-labs/sealed-secrets"],
      "replacementName": "github.com/bitnami/sealed-secrets",
      "replacementVersion": "v0.38.1"
    }
  ]
}
